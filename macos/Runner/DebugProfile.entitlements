<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox is deliberately OFF: this build is unsigned/unnotarized,
	     local-testing-only (see .github/workflows/macos-build.yml), never
	     App Store bound, so sandboxing buys nothing. It was actively
	     breaking whixp's SQLite database: _getDatabasePath() hand-builds
	     "$HOME/Library/Application Support/whixp" from Platform.environment,
	     which under App Sandbox still reports the *real* home directory even
	     though only the app's container path is actually writable - every
	     open/create attempt was denied, initialize() threw after retries,
	     and that exception propagated straight into a connectionFailure
	     reconnect loop with no XMPP traffic ever sent. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
</dict>
</plist>
